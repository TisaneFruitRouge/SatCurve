# ---- Network ----
STACKS_NETWORK=devnet          # devnet | testnet | mainnet
STACKS_API_URL=http://localhost:3999

# ---- Relayer wallet ----
# Hex-encoded Stacks private key. This wallet must be:
#   - an authorized relayer in yield-oracle.clar (authorize-relayer)
#   - the deployer / contract-owner of bond-factory.clar
BOT_PRIVATE_KEY=

# ---- Contract addresses (format: <deployer-address>.<contract-name>) ----
BOND_FACTORY_ADDRESS=
YIELD_ORACLE_ADDRESS=

# ---- Optional ----
LOG_LEVEL=info   # debug | info | warn | error
